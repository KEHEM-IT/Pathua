# Extension environment — used at build time by Vite (import.meta.env.VITE_*)
# Copy to .env.local and fill in real values. Never commit .env.local.

# Your Firebase Web API Key (NOT the service account — the client-side key)
# Found in: Firebase Console → Project Settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY=REPLACE_WITH_FIREBASE_WEB_API_KEY

# Your deployed backend URL (Vercel deployment URL)
VITE_API_BASE_URL=https://pathua-api.vercel.app/api

# Your Google OAuth Client ID (same one used in manifest.json oauth2.client_id)
VITE_GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com

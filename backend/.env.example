# Backend environment variables — copy to .env and fill in real values.
# NEVER commit .env to source control.

# ---- Firebase ----
# Paste the entire service account JSON as a single-line string.
# Get it from: Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"YOUR_PROJECT_ID",...}

# ---- CORS ----
# Your production Chrome extension origin (chrome-extension://YOUR_EXTENSION_ID)
ALLOWED_ORIGIN=chrome-extension://REPLACE_WITH_YOUR_EXTENSION_ID

# ---- Server ----
PORT=4000
NODE_ENV=development
